{
	"name": "@agentlayerweb/react",
	"version": "0.1.3",
	"description": "React components for AgentLayerWeb semantic annotations — make your React app natively understandable to AI agents",
	"license": "MIT",
	"homepage": "https://github.com/theajmalrazaq/agentlayerweb#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/theajmalrazaq/agentlayerweb.git",
		"directory": "packages/react"
	},
	"keywords": [
		"ai",
		"agents",
		"react",
		"browser-use",
		"webmcp",
		"semantic",
		"agentlayerweb"
	],
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"type": "module",
	"scripts": {
		"build": "tsup src/index.tsx --format esm,cjs --dts --clean",
		"dev": "tsup src/index.tsx --format esm,cjs --dts --watch",
		"test": "vitest run",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@agentlayerweb/core": "^0.1.0"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@types/react": "^18.2.0",
		"react": "^18.2.0",
		"tsup": "^8.5.1",
		"typescript": "^5.3.3",
		"vitest": "^1.3.1"
	}
}
