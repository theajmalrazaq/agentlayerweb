{
	"name": "@agentlayerweb/vue",
	"version": "0.1.3",
	"description": "Vue 3 directives for AgentLayerWeb semantic annotations — make your Vue app natively understandable to AI agents",
	"license": "MIT",
	"homepage": "https://github.com/theajmalrazaq/agentlayerweb#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/theajmalrazaq/agentlayerweb.git",
		"directory": "packages/vue"
	},
	"keywords": [
		"ai",
		"agents",
		"vue",
		"vue3",
		"browser-use",
		"webmcp",
		"semantic",
		"agentlayerweb"
	],
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"type": "module",
	"scripts": {
		"build": "tsup src/index.ts --format esm,cjs --dts --clean",
		"dev": "tsup src/index.ts --format esm,cjs --dts --watch",
		"test": "vitest run",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@agentlayerweb/core": "^0.1.0"
	},
	"peerDependencies": {
		"vue": "^3.0.0"
	},
	"devDependencies": {
		"tsup": "^8.5.1",
		"typescript": "^5.3.3",
		"vitest": "^1.3.1",
		"vue": "^3.3.0"
	}
}
