{
	"name": "@agentlayerweb/vite-plugin",
	"version": "0.1.3",
	"description": "Vite & Next.js plugin that auto-annotates your app with AgentLayerWeb semantic attributes at build time. Zero manual markup needed.",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"license": "MIT",
	"scripts": {
		"build": "tsup src/index.ts --format cjs,esm --dts",
		"dev": "tsup src/index.ts --format cjs,esm --dts --watch"
	},
	"keywords": [
		"vite-plugin",
		"next",
		"agentlayerweb",
		"ai",
		"agents",
		"automation"
	],
	"peerDependencies": {
		"vite": ">=4.0.0"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.0.0",
		"vite": "^5.0.0"
	},
	"dependencies": {
		"@babel/parser": "^7.24.0",
		"@babel/traverse": "^7.24.0",
		"@babel/types": "^7.24.0"
	}
}
